{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "NovelHub backlog",
  "type": "object",
  "required": ["schema_version", "project", "current_milestone", "updated_at", "tasks"],
  "properties": {
    "schema_version": {"const": 1},
    "project": {"const": "novelhub"},
    "current_milestone": {"type": "string", "minLength": 1},
    "updated_at": {"type": "string", "format": "date-time"},
    "tasks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id", "title", "milestone", "priority", "weight", "state",
          "owner", "branch", "depends_on", "owned_paths", "task_packet",
          "handoff", "qa_report", "review_report", "docs_impact",
          "blocked_by", "history", "updated_at"
        ],
        "properties": {
          "id": {"type": "string", "pattern": "^NH-[A-Z]+-[0-9]{3}$"},
          "priority": {"enum": ["P0", "P1", "P2", "P3"]},
          "weight": {"type": "integer", "minimum": 1},
          "state": {
            "enum": [
              "proposed", "planning", "needs_decision", "ready",
              "in_progress", "blocked", "dev_complete", "qa_failed",
              "qa_passed", "review_failed", "accepted", "done", "superseded"
            ]
          },
          "owner": {"type": ["string", "null"]},
          "branch": {"type": ["string", "null"]},
          "depends_on": {"type": "array", "items": {"type": "string"}},
          "owned_paths": {"type": "array", "items": {"type": "string"}},
          "task_packet": {"type": "string"},
          "handoff": {"type": ["string", "null"]},
          "qa_report": {"type": ["string", "null"]},
          "review_report": {"type": ["string", "null"]},
          "docs_impact": {"enum": ["pending", "none", "resolved"]},
          "blocked_by": {"type": "array", "items": {"type": "string"}},
          "history": {"type": "array", "minItems": 1},
          "updated_at": {"type": "string", "format": "date-time"}
        }
      }
    }
  }
}
