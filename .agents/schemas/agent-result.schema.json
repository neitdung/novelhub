{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "NovelHub agent result",
  "type": "object",
  "required": [
    "task_id", "role", "result", "summary", "changed_paths",
    "checks", "risks", "blockers", "artifact", "recommended_state"
  ],
  "properties": {
    "task_id": {"type": "string", "pattern": "^NH-[A-Z]+-[0-9]{3}$"},
    "role": {"enum": ["manager", "planner", "developer", "qa", "reviewer", "docs"]},
    "result": {"enum": ["completed", "failed", "blocked", "needs_decision"]},
    "summary": {"type": "string"},
    "changed_paths": {"type": "array", "items": {"type": "string"}},
    "checks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["command", "status"],
        "properties": {
          "command": {"type": "string"},
          "status": {"enum": ["passed", "failed", "not_run"]}
        }
      }
    },
    "risks": {"type": "array", "items": {"type": "string"}},
    "blockers": {"type": "array", "items": {"type": "string"}},
    "artifact": {"type": ["string", "null"]},
    "recommended_state": {"type": ["string", "null"]}
  }
}
